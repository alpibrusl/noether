{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Noether Stage Specification",
  "description": "JSON format for noether stage add <spec.json>. Supports two formats: simple (recommended for authoring) and full (for importing pre-signed stages).",
  "oneOf": [
    { "$ref": "#/definitions/simple_spec" },
    { "$ref": "#/definitions/full_stage" }
  ],
  "definitions": {
    "ntype": {
      "description": "NType — Noether structural type. Accepts both simplified syntax (\"Text\", {\"Record\": [[\"field\", \"Type\"]]}) and canonical syntax ({\"kind\": \"Text\"}, {\"kind\": \"Record\", \"value\": {\"field\": {\"kind\": \"Text\"}}}).",
      "oneOf": [
        {
          "type": "string",
          "enum": ["Text", "Number", "Bool", "Null", "Any", "Bytes", "VNode"],
          "description": "Primitive type shorthand"
        },
        {
          "type": "object",
          "description": "Complex type — Record, List, Map, Union, Stream (simplified or canonical format)"
        }
      ]
    },
    "effect": {
      "type": "string",
      "enum": ["Pure", "Fallible", "Network", "Process", "NonDeterministic"],
      "description": "Side effect declaration"
    },
    "example": {
      "type": "object",
      "required": ["input", "output"],
      "properties": {
        "input": { "description": "Example input value" },
        "output": { "description": "Expected output value" }
      }
    },
    "simple_spec": {
      "type": "object",
      "description": "Simple spec format — recommended for authoring new stages. The CLI computes the content hash, signs the stage, and registers it.",
      "required": ["name", "implementation"],
      "not": { "required": ["id"] },
      "properties": {
        "name": {
          "type": "string",
          "description": "Stage name (snake_case)"
        },
        "description": {
          "type": "string",
          "description": "One-sentence description starting with a verb. Defaults to name if omitted."
        },
        "input": {
          "$ref": "#/definitions/ntype",
          "description": "Input type (simplified or canonical NType syntax)"
        },
        "output": {
          "$ref": "#/definitions/ntype",
          "description": "Output type (simplified or canonical NType syntax)"
        },
        "effects": {
          "type": "array",
          "items": { "$ref": "#/definitions/effect" },
          "description": "Side effects. Defaults to [\"Pure\"] if omitted."
        },
        "language": {
          "type": "string",
          "default": "python",
          "description": "Implementation language. Defaults to \"python\"."
        },
        "implementation": {
          "oneOf": [
            { "type": "string", "description": "Source code as a string" },
            {
              "type": "object",
              "required": ["code", "language"],
              "properties": {
                "code": { "type": "string" },
                "language": { "type": "string" }
              }
            }
          ],
          "description": "Stage implementation — either a code string or {code, language} object"
        },
        "examples": {
          "type": "array",
          "items": { "$ref": "#/definitions/example" },
          "description": "Input/output examples. Minimum 5 recommended."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Browsable category tags for discovery"
        },
        "aliases": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Alternative names for search recall"
        }
      }
    },
    "full_stage": {
      "type": "object",
      "description": "Full Stage format — for importing pre-signed or pre-hashed stages.",
      "required": ["id", "signature", "description", "examples", "lifecycle"],
      "properties": {
        "id": {
          "type": "string",
          "description": "SHA-256 content hash of the stage signature (64 hex chars)"
        },
        "signature_id": {
          "type": ["string", "null"],
          "description": "SHA-256 of (name + input + output + effects). Stable across 1.x per STABILITY.md — a bugfix that changes `implementation_hash` changes `id` but not `signature_id`, so graphs pinned by signature keep working. Auto-computed by the builder."
        },
        "canonical_id": {
          "type": ["string", "null"],
          "description": "Deprecated alias for `signature_id` — accepted on deserialisation for v0.5.x back-compat; removed in v0.7.0."
        },
        "signature": {
          "type": "object",
          "required": ["input", "output", "effects", "implementation_hash"],
          "properties": {
            "input": { "description": "NType — input type of the stage" },
            "output": { "description": "NType — output type of the stage" },
            "effects": { "type": "object", "description": "EffectSet declaring side effects" },
            "implementation_hash": { "type": "string", "description": "SHA-256 of implementation code" }
          }
        },
        "capabilities": {
          "type": "array",
          "items": { "type": "string", "enum": ["Network", "FsRead", "FsWrite", "Gpu", "Llm"] }
        },
        "cost": {
          "type": "object",
          "properties": {
            "time_ms_p50": { "type": ["integer", "null"] },
            "tokens_est": { "type": ["integer", "null"] },
            "memory_mb": { "type": ["integer", "null"] }
          }
        },
        "description": { "type": "string" },
        "examples": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/example" }
        },
        "lifecycle": {
          "type": "string",
          "enum": ["Draft", "Active"],
          "description": "Initial lifecycle state"
        },
        "ed25519_signature": { "type": ["string", "null"] },
        "signer_public_key": { "type": ["string", "null"] },
        "implementation_code": { "type": ["string", "null"] },
        "implementation_language": { "type": ["string", "null"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "aliases": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
